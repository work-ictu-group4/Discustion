name: Product Feature
description: Product-level feature
labels: ["type:feature"]

body:
  - type: textarea
    id: feature_description
    attributes:
      label: Feature Description
      description: Describe the product feature

  - type: dropdown
    id: status
    attributes:
      label: Status
      options:
        - Proposed
        - Approved
        - Implemented
        - Validated

  - type: dropdown
    id: priority
    attributes:
      label: Priority
      options:
        - Must
        - Should
        - Could
        - Won't

  - type: dropdown
    id: difficulty
    attributes:
      label: Difficulty
      options:
        - Low
        - Medium
        - High

  - type: dropdown
    id: stability
    attributes:
      label: Stability
      options:
        - High
        - Medium
        - Low

  - type: input
    id: target_version
    attributes:
      label: Target Version
      placeholder: v1.0

  - type: input
    id: rationale
    attributes:
      label: Rationale
      description: Why this feature is needed

  - type: input
    id: cost
    attributes:
      label: Cost
      placeholder: Estimated development cost

  - type: input
    id: defect
    attributes:
      label: Defect
      description: Related defect if any

  - type: input
    id: planned_iteration
    attributes:
      label: Planned Iteration
      placeholder: Sprint 1

  - type: input
    id: actual_iteration
    attributes:
      label: Actual Iteration
      placeholder: Sprint 2

  - type: textarea
    id: origin
    attributes:
      label: Origin (Trace From)
      description: Link related Need issues (e.g. #12)
      placeholder: "#012"
